# Copie para .env na mesma pasta: cp .env.example .env
# Preencha GOOGLE_* (OAuth Web no Google Cloud Console). O restante serve para MySQL no Docker.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MySQL no Docker (./run-dev-mysql.sh). Porta 3307 no host evita conflito com MySQL nativo na 3306.
MYSQL_HOST_PORT=3307
SPRING_PROFILES_ACTIVE=mysql
MYSQL_URL=jdbc:mysql://127.0.0.1:3307/climbe?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&serverTimezone=America/Sao_Paulo&allowPublicKeyRetrieval=true&useSSL=false
MYSQL_USERNAME=root
MYSQL_PASSWORD=climbe_dev_root

# Opcional
# JWT_SECRET=
# APP_FRONTEND_URL=http://localhost:5173
